{
    "skip": ["misc", "nix-channels-index"],
    "base": {
        "extension": "D",
        "endpoints": [
            {
                "label": "njxzu",
                "public": true,
                "resolve": "mirrors.njxzu.cn",
                "filter": ["V4", "V6", "SSL", "NOSSL"],
                "range": [
                    "COUNTRY:CN",
                    "REGION:JS",
                    "ISP:CERNET"
                ]
            },
            {
                "label": "njxzu4",
                "public": true,
                "resolve": "ipv4.mirrors.njxzu.cn",
                "filter": ["V4", "SSL", "NOSSL"],
                "range": [
                    "COUNTRY:CN",
                    "REGION:JS"
                ]
            },
            {
                "label": "njxzu6",
                "public": true,
                "resolve": "ipv6.mirrors.njxzu.cn",
                "filter": ["V6", "SSL", "NOSSL"],
                "range": [
                    "COUNTRY:CN",
                    "REGION:JS",
                    "ISP:CERNET"
                ]
            }
        ],
        "site": {
            "url": "https://mirrors.njxzu.cn",
            "logo": "https://mirrors.njxzu.cn/static/img/njxzu-mirrors.svg",
            "logo_darkmode": "https://mirrors.njxzu.cn/static/img/njxzu-mirrors.svg",
            "abbr": "NX OpenAtom",
            "name": "南晓开放原子社开源软件镜像",
            "homepage": "https://www.njxzc.edu.cn/",
            "issue": "mailto:mirror@openatom.njxzu.cn",
            "request": "mailto:mirror@openatom.njxzu.cn",
            "email": "mirror@openatom.njxzu.cn",
            "group": "南晓开放原子社",
            "big": "/.well-known/mirror-test/1GB.bin"
        }
    }
}
