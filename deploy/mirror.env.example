# NJXZU Mirrors deployment settings.
# Copy to /etc/njxzu-mirrors.env and adjust before running deploy scripts.

MIRROR_NAME=NJXZU
MIRROR_DOMAIN=mirrors.njxzc.edu.cn
MIRROR_BASE_URL=https://mirrors.njxzc.edu.cn
MIRROR_CONTACT_EMAIL=mirror-admin@njxzc.edu.cn

MIRROR_ROOT=/srv/mirror
MIRROR_WEB_ROOT=/srv/mirror/www
MIRROR_HTTPDIR=/srv/mirror/www
MIRROR_OUTDIR=/srv/mirror/www
MIRROR_SRC_DIR=/opt/njxzu-mirrors-index
MIRROR_USER=mirror
MIRROR_GROUP=mirror

MIRROR_HELP_URL=https://help.mirrors.cernet.edu.cn/
MIRROR_STATUS_URL=/status/
MIRROR_STATUS_JSON_URL=/status/json
MIRROR_ABOUT_URL=https://www.njxzc.edu.cn/
MIRROR_NEWS_URL=
MIRROR_NEWS_FEED=
MIRROR_REQUEST_URL=mailto:mirror-admin@njxzc.edu.cn?subject=New%20mirror%20request
MIRROR_ISSUE_URL=mailto:mirror-admin@njxzc.edu.cn?subject=Mirror%20issue

YUKI_LISTEN=127.0.0.1:9999
# setup-yuki.sh enables this after yukid is installed.
# MIRROR_YUKI_URL=http://127.0.0.1:9999/api/v1/metas
YUKI_CONFIG_DIR=/etc/yuki/repos
YUKI_LOG_DIR=/var/log/yuki
YUKI_DB=/var/lib/yuki/yukid.db
