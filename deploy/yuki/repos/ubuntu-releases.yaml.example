name: ubuntu-releases
cron: "37 */6 * * *"
storageDir: /srv/mirror/www/ubuntu-releases
image: ustcmirror/rsync:latest
logRotCycle: 5
retry: 1
envs:
  RSYNC_HOST: rsync.mirrors.ustc.edu.cn
  RSYNC_PATH: ubuntu-releases/
  RSYNC_EXCLUDE: --exclude=.~tmp~/
  RSYNC_MAXDELETE: "10000"
  $UPSTREAM: rsync://rsync.mirrors.ustc.edu.cn/ubuntu-releases/
