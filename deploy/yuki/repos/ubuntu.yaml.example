name: ubuntu
cron: "17 */6 * * *"
storageDir: /srv/mirror/www/ubuntu
image: ustcmirror/rsync:latest
logRotCycle: 5
retry: 1
envs:
  RSYNC_HOST: rsync.mirrors.ustc.edu.cn
  RSYNC_PATH: ubuntu/
  RSYNC_EXCLUDE: --exclude=.~tmp~/
  RSYNC_MAXDELETE: "100000"
  $UPSTREAM: rsync://rsync.mirrors.ustc.edu.cn/ubuntu/
